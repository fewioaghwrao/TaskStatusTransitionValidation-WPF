<UserControl x:Class="TaskStatusWpf.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TaskStatusWpf.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <!-- カード影 -->
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="18"
                          ShadowDepth="4"
                          Opacity="0.25"/>

        <!-- 入力共通 -->
        <Style x:Key="InputStyle" TargetType="{x:Type Control}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource InputStyle}"/>
        <Style TargetType="{x:Type PasswordBox}" BasedOn="{StaticResource InputStyle}"/>

        <!-- メインボタン -->
        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border CornerRadius="10" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#93C5FD"/>
                                <Setter Property="Foreground" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- サブボタン（表示/非表示） -->
        <Style x:Key="SubButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="#F8FAFC">
        <Border Width="480"
                Padding="28"
                CornerRadius="16"
                Background="White"
                Effect="{StaticResource CardShadow}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- タイトル -->
                <StackPanel Grid.Row="0" Margin="0,0,0,18">
                    <TextBlock Text="サインイン" FontSize="22" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="アカウント情報を入力してください"
                               Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="#6B7280"/>
                </StackPanel>

                <!-- エラーバナー -->
                <Border Grid.Row="1"
                        CornerRadius="10"
                        Background="#FEF2F2"
                        BorderBrush="#FCA5A5"
                        BorderThickness="1"
                        Padding="12"
                        Margin="0,0,0,14"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#B91C1C"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Email -->
                <StackPanel Grid.Row="2" Margin="0,0,0,12">
                    <TextBlock Text="メールアドレス" FontSize="12" Foreground="#374151" Margin="2,0,0,6"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Password -->
                <StackPanel Grid.Row="3" Margin="0,0,0,16">
                    <TextBlock Text="パスワード" FontSize="12" Foreground="#374151" Margin="2,0,0,6"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="88"/>
                        </Grid.ColumnDefinitions>

                        <!-- 非表示 -->
                        <PasswordBox x:Name="PasswordBox"
                                     Grid.Column="0"
                                     Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                        <!-- 表示 -->
                        <TextBox x:Name="PasswordTextBox"
                                 Grid.Column="0"
                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsPasswordVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <Button Grid.Column="2"
                                Content="{Binding PasswordToggleText}"
                                Command="{Binding TogglePasswordVisibilityCommand}"
                                Style="{StaticResource SubButtonStyle}"/>
                    </Grid>
                </StackPanel>

                <!-- ログイン -->
                <Button Grid.Row="4"
                        Content="ログイン"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                <!-- 処理中 -->
                <TextBlock Grid.Row="5"
                           Text="処理中…"
                           Margin="0,12,0,0"
                           HorizontalAlignment="Center"
                           Foreground="#6B7280"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>